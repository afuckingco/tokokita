<%- include('_layout_top', { title: 'Detail Pesanan #' + order.id }) %>

<a href="/admin/orders">&larr; Kembali ke daftar pesanan</a>
<h1>Pesanan #<%= order.id %></h1>

<div class="order-detail-grid">
  <div>
    <h3>Info Pelanggan</h3>
    <p><strong>Nama:</strong> <%= order.customer_name %></p>
    <p><strong>HP:</strong> <%= order.customer_phone %></p>
    <p><strong>Alamat:</strong> <%= order.customer_address %></p>
    <p><strong>Tanggal:</strong> <%= order.created_at %></p>
  </div>

  <div>
    <h3>Status Pesanan</h3>
    <form action="/admin/orders/<%= order.id %>/status" method="POST" class="admin-form-inline">
      <%- include('../partials/csrf') %>
      <select name="status">
        <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
        <option value="diproses" <%= order.status === 'diproses' ? 'selected' : '' %>>Diproses</option>
        <option value="dikirim" <%= order.status === 'dikirim' ? 'selected' : '' %>>Dikirim</option>
        <option value="selesai" <%= order.status === 'selesai' ? 'selected' : '' %>>Selesai</option>
        <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Dibatalkan</option>
      </select>
      <button type="submit" class="btn-primary">Update Status</button>
    </form>
  </div>
</div>

<h3>Item Pesanan</h3>
<table class="admin-table">
  <thead>
    <tr><th>Produk</th><th>Harga</th><th>Qty</th><th>Subtotal</th></tr>
  </thead>
  <tbody>
    <% items.forEach(i => { %>
      <tr>
        <td><%= i.product_name %></td>
        <td><%= formatRupiah(i.price) %></td>
        <td><%= i.qty %></td>
        <td><%= formatRupiah(i.price * i.qty) %></td>
      </tr>
    <% }) %>
  </tbody>
</table>
<p class="cart-total"><strong>Total: <%= formatRupiah(order.total) %></strong></p>

<%- include('_layout_bottom') %>
