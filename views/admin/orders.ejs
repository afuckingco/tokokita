<%- include('_layout_top', { title: 'Kelola Pesanan' }) %>

<h1>Pesanan</h1>

<table class="admin-table">
  <thead>
    <tr>
      <th>ID</th>
      <th>Pelanggan</th>
      <th>Total</th>
      <th>Status</th>
      <th>Tanggal</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% orders.forEach(o => { %>
      <tr>
        <td>#<%= o.id %></td>
        <td><%= o.customer_name %></td>
        <td><%= formatRupiah(o.total) %></td>
        <td><span class="status-pill status-<%= o.status %>"><%= o.status %></span></td>
        <td><%= o.created_at %></td>
        <td><a href="/admin/orders/<%= o.id %>" class="btn-edit">Detail</a></td>
      </tr>
    <% }) %>
    <% if (orders.length === 0) { %>
      <tr><td colspan="6">Belum ada pesanan.</td></tr>
    <% } %>
  </tbody>
</table>

<%- include('_layout_bottom') %>
